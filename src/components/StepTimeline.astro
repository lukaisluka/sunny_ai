---
const { steps = [] } = Astro.props;
---

<div class="timeline">
  {steps.map((step, index) => (
    <div class="timeline-item">
      <div class="timeline-number">{index + 1}</div>
      <div class="card">
        <h3>{step.title}</h3>
        <p>{step.description}</p>
      </div>
    </div>
  ))}
</div>
